{
    "name": "antigravity-session-trace",
    "displayName": "Antigravity Session Trace",
    "description": "Browse, search, tag, and manage your Antigravity conversations.",
    "version": "0.1.0",
    "publisher": "Dongmayyys",
    "repository": {
        "type": "git",
        "url": "https://github.com/Dongmayyys/antigravity-session-trace"
    },
    "engines": {
        "vscode": "^1.96.0"
    },
    "icon": "images/icon.png",
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "l10n": "./l10n",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "antigravity-conv-manager",
                    "title": "%viewsContainers.conversations.title%",
                    "icon": "$(comment-discussion)"
                }
            ]
        },
        "views": {
            "antigravity-conv-manager": [
                {
                    "id": "convManager.sessions",
                    "name": "%views.sessions.name%"
                }
            ]
        },
        "commands": [
            {
                "command": "convManager.refresh",
                "title": "%commands.refresh%",
                "icon": "$(refresh)",
                "category": "%category%"
            },
            {
                "command": "convManager.openSession",
                "title": "%commands.openSession%",
                "icon": "$(open-preview)",
                "category": "%category%"
            },
            {
                "command": "convManager.search",
                "title": "%commands.search%",
                "icon": "$(search)",
                "category": "%category%"
            },
            {
                "command": "convManager.sortBy",
                "title": "%commands.sortBy%",
                "icon": "$(list-ordered)",
                "category": "%category%"
            },
            {
                "command": "convManager.filterWorkspace",
                "title": "%commands.filterWorkspace%",
                "icon": "$(filter)",
                "category": "%category%"
            },
            {
                "command": "convManager.summarize",
                "title": "%commands.summarize%",
                "icon": "$(sparkle)",
                "category": "%category%"
            },
            {
                "command": "convManager.showStats",
                "title": "%commands.showStats%",
                "icon": "$(graph)",
                "category": "%category%"
            },
            {
                "command": "convManager.setApiKey",
                "title": "%commands.setApiKey%",
                "icon": "$(key)",
                "category": "%category%"
            },
            {
                "command": "convManager.star",
                "title": "%commands.star%",
                "icon": "$(star-empty)",
                "category": "%category%"
            },
            {
                "command": "convManager.unstar",
                "title": "%commands.unstar%",
                "icon": "$(star-full)",
                "category": "%category%"
            },
            {
                "command": "convManager.showTokenDashboard",
                "title": "%commands.showTokenDashboard%",
                "icon": "$(graph)",
                "category": "%category%"
            },
            {
                "command": "convManager.viewRecent",
                "title": "%commands.viewRecent%",
                "icon": "$(clock)",
                "category": "%category%"
            },
            {
                "command": "convManager.viewSessions",
                "title": "%commands.viewSessions%",
                "icon": "$(list-unordered)",
                "category": "%category%"
            },
            {
                "command": "convManager.copyId",
                "title": "%commands.copyId%",
                "icon": "$(clippy)",
                "category": "%category%"
            },
            {
                "command": "convManager.revealInExplorer",
                "title": "%commands.revealInExplorer%",
                "icon": "$(folder-opened)",
                "category": "%category%"
            },
            {
                "command": "convManager.toggleArchive",
                "title": "%commands.toggleArchive%",
                "icon": "$(archive)",
                "category": "%category%"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "convManager.viewRecent",
                    "when": "view == convManager.sessions && convManager.viewMode != 'recent'",
                    "group": "navigation@0"
                },
                {
                    "command": "convManager.viewSessions",
                    "when": "view == convManager.sessions && convManager.viewMode == 'recent'",
                    "group": "navigation@0"
                },
                {
                    "command": "convManager.search",
                    "when": "view == convManager.sessions",
                    "group": "navigation@1"
                },
                {
                    "command": "convManager.filterWorkspace",
                    "when": "view == convManager.sessions",
                    "group": "navigation@2"
                },
                {
                    "command": "convManager.sortBy",
                    "when": "view == convManager.sessions && convManager.viewMode != 'recent'",
                    "group": "navigation@3"
                },
                {
                    "command": "convManager.refresh",
                    "when": "view == convManager.sessions",
                    "group": "navigation@4"
                },
                {
                    "command": "convManager.showTokenDashboard",
                    "when": "view == convManager.sessions",
                    "group": "navigation@5"
                }
            ],
            "view/item/context": [
                {
                    "command": "convManager.star",
                    "when": "view == convManager.sessions && viewItem == session",
                    "group": "inline@1"
                },
                {
                    "command": "convManager.unstar",
                    "when": "view == convManager.sessions && viewItem == sessionStarred",
                    "group": "inline@1"
                },
                {
                    "command": "convManager.toggleArchive",
                    "when": "view == convManager.sessions && viewItem =~ /^session(Starred)?$/",
                    "group": "inline@2"
                },
                {
                    "command": "convManager.summarize",
                    "when": "view == convManager.sessions && viewItem =~ /^session(Starred)?$/",
                    "group": "1_actions@0"
                },
                {
                    "command": "convManager.copyId",
                    "when": "view == convManager.sessions && viewItem =~ /^session/",
                    "group": "1_actions@1"
                },
                {
                    "command": "convManager.revealInExplorer",
                    "when": "view == convManager.sessions && viewItem =~ /^session/",
                    "group": "1_actions@2"
                }
            ]
        },
        "configuration": {
            "title": "%config.title%",
            "properties": {
                "convManager.ai.endpoint": {
                    "order": 1,
                    "type": "string",
                    "default": "",
                    "markdownDescription": "%config.ai.endpoint.markdownDescription%"
                },
                "convManager.ai.format": {
                    "order": 2,
                    "type": "string",
                    "enum": [
                        "openai",
                        "gemini"
                    ],
                    "default": "openai",
                    "description": "%config.ai.format.description%"
                },
                "convManager.ai.model": {
                    "order": 3,
                    "type": "string",
                    "default": "",
                    "description": "%config.ai.model.description%"
                },
                "convManager.ai.prompt": {
                    "order": 4,
                    "type": "string",
                    "default": "",
                    "markdownDescription": "%config.ai.prompt.markdownDescription%",
                    "editPresentation": "multilineText"
                },
                "convManager.ai.autoSummarize": {
                    "order": 5,
                    "type": "string",
                    "enum": [
                        "ask",
                        "on",
                        "off"
                    ],
                    "default": "ask",
                    "markdownDescription": "%config.ai.autoSummarize.markdownDescription%"
                },
                "convManager.ai.minMessages": {
                    "order": 6,
                    "type": "number",
                    "default": 5,
                    "description": "%config.ai.minMessages.description%"
                },
                "convManager.ai.cooldownHours": {
                    "order": 7,
                    "type": "number",
                    "default": 2,
                    "description": "%config.ai.cooldownHours.description%"
                },
                "convManager.ai.staleThreshold": {
                    "order": 8,
                    "type": "number",
                    "default": 5,
                    "description": "%config.ai.staleThreshold.description%"
                },
                "convManager.archiveKeywords": {
                    "order": 9,
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "markdownDescription": "%config.archiveKeywords.markdownDescription%"
                }
            }
        }
    },
    "scripts": {
        "compile": "node esbuild.js",
        "compile:production": "node esbuild.js --production",
        "watch": "node esbuild.js --watch",
        "package": "node esbuild.js --production && npx @vscode/vsce package --no-dependencies",
        "lint": "eslint src"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.96.0",
        "esbuild": "^0.27.2",
        "typescript": "^5.3.0"
    },
    "dependencies": {
        "@vscode/l10n": "^0.0.18",
        "marked": "^17.0.3"
    }
}